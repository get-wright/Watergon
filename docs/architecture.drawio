          <mxGeometry x="60" y="180" width="1700" height="1390" as="geometry"/>
        </mxCell>

        <!-- VPC info strip -->
        <mxCell id="vpc" value="VPC mk8s-poc-net  •  subnet mk8s-poc-subnet  •  Cloud NAT (egress only)  •  asia-southeast1-c" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1f5fe;strokeColor=#0288d1;strokeWidth=1;fontSize=12;fontStyle=2" vertex="1" parent="1">
          <mxGeometry x="80" y="210" width="1660" height="40" as="geometry"/>
        </mxCell>

        <!-- =================== VM CONTAINER =================== -->
        <mxCell id="vm" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff5f5;strokeColor=#b85450;strokeWidth=2;fontSize=13;verticalAlign=top" vertex="1" parent="1">
          <mxGeometry x="80" y="270" width="1660" height="1280" as="geometry"/>
        </mxCell>

        <mxCell id="vmHeader" value="VM host  (Ubuntu 22.04 — Packer-baked image &lt;b&gt;watergon-lab&lt;/b&gt;)" style="text;html=1;align=left;verticalAlign=middle;fontSize=13;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="100" y="280" width="1620" height="24" as="geometry"/>
        </mxCell>

        <!-- systemd unit -->
        <mxCell id="systemd" value="&lt;b&gt;systemd: watergon-dashboard-pf.service&lt;/b&gt;  →  kubectl port-forward svc/dashboard 8443:443 --address=0.0.0.0&#10;waits for ready endpoints • Restart=always" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12" vertex="1" parent="1">
          <mxGeometry x="100" y="310" width="1620" height="56" as="geometry"/>
        </mxCell>

        <!-- =================== KIND CLUSTER =================== -->
        <mxCell id="kind" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;strokeWidth=2;fontSize=13;verticalAlign=top" vertex="1" parent="1">
          <mxGeometry x="100" y="380" width="1620" height="850" as="geometry"/>
        </mxCell>

        <mxCell id="kindHeader" value="kind cluster &lt;b&gt;security-lab&lt;/b&gt;   (3 nodes: control-plane + worker + worker2 — Docker-in-Docker)" style="text;html=1;align=left;verticalAlign=middle;fontSize=13;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="120" y="390" width="1580" height="24" as="geometry"/>
        </mxCell>

        <!-- ========== NAMESPACE: KUBE-SYSTEM ========== -->
        <mxCell id="ns_kube" value="namespace: kube-system" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;fontSize=13;verticalAlign=top;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="120" y="430" width="420" height="780" as="geometry"/>
        </mxCell>

        <mxCell id="tetragon" value="&lt;b&gt;Tetragon DS&lt;/b&gt;&#10;eBPF kernel hooks&#10;process_exec / exit / kprobe&#10;TracingPolicy CRDs&#10;allowlist: vulnerable-apps,&#10;security-testing&#10;writes JSON →&#10;/var/run/cilium/tetragon/&#10;tetragon.log" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6ffe6;strokeColor=#82b366;fontSize=11;verticalAlign=top" vertex="1" parent="1">
          <mxGeometry x="140" y="470" width="380" height="200" as="geometry"/>
        </mxCell>

        <mxCell id="metrics" value="&lt;b&gt;metrics-server&lt;/b&gt;&#10;--kubelet-insecure-tls" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6ffe6;strokeColor=#82b366;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="140" y="690" width="380" height="60" as="geometry"/>
        </mxCell>

        <!-- host log file (still in kube-system column, below boxes) -->
        <mxCell id="hostlog" value="&lt;b&gt;hostPath  /var/run/cilium/tetragon/tetragon.log&lt;/b&gt;&#10;per-node • JSON lines • shared with agent DS" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=2;fontSize=11;dashed=1" vertex="1" parent="1">
          <mxGeometry x="140" y="800" width="380" height="60" as="geometry"/>
        </mxCell>

        <!-- ruleset summary inside kube-system column -->
        <mxCell id="ruleset" value="&lt;b&gt;Tetragon ruleset 700000–700099&lt;/b&gt;&#10;&#10;700000/1/2 base decoders (silenced, level 0)&#10;700004 shell • 700005 reads • 700006 pkg-mgr&#10;700007 sensitive file • 700008 priv-esc&#10;700010/11 ns-aware • 700020 tcp_connect&#10;700099 audit — every exec in vulnerable-apps" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;verticalAlign=top" vertex="1" parent="1">
          <mxGeometry x="140" y="880" width="380" height="160" as="geometry"/>
        </mxCell>

        <mxCell id="rulesync" value="&lt;b&gt;wazuh-rules-sync Job&lt;/b&gt;&#10;creates k8s-nodes group&#10;cp rules → master + worker" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="140" y="1060" width="380" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="kubenote" value="(rules-sync Job actually runs in wazuh ns — drawn here for grouping)" style="text;html=1;align=center;verticalAlign=middle;fontSize=10;fontStyle=2" vertex="1" parent="1">
          <mxGeometry x="140" y="1150" width="380" height="40" as="geometry"/>
        </mxCell>

        <!-- ========== NAMESPACE: WAZUH ========== -->
        <mxCell id="ns_wazuh" value="namespace: wazuh" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;strokeWidth=2;fontSize=13;verticalAlign=top;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="570" y="430" width="600" height="780" as="geometry"/>
        </mxCell>

        <mxCell id="wm_master" value="&lt;b&gt;wazuh-manager-master&lt;/b&gt;&#10;StatefulSet  •  cluster master&#10;authd :1515  •  API :55000&#10;owns rule sync" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff8e1;strokeColor=#d79b00;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="590" y="470" width="270" height="110" as="geometry"/>
        </mxCell>

        <mxCell id="wm_worker" value="&lt;b&gt;wazuh-manager-worker&lt;/b&gt;&#10;StatefulSet  •  analysisd&#10;ingests :1514 from agents&#10;writes alerts.json + archives" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff8e1;strokeColor=#d79b00;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="880" y="470" width="270" height="110" as="geometry"/>
        </mxCell>

        <mxCell id="indexer" value="&lt;b&gt;wazuh-indexer  (OpenSearch)&lt;/b&gt;&#10;StatefulSet  •  PVC rancher.io/local-path&#10;index: wazuh-alerts-*" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff8e1;strokeColor=#d79b00;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="590" y="600" width="560" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="dashboard" value="&lt;b&gt;wazuh-dashboard  (OpenSearch Dashboards)&lt;/b&gt;&#10;Deployment  •  ClusterIP svc/dashboard:443 → :5601" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff8e1;strokeColor=#d79b00;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="590" y="700" width="560" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="agentds" value="&lt;b&gt;wazuh-agent  DaemonSet&lt;/b&gt;&#10;custom image: wazuh-agent-local:4.14.1&#10;hostNetwork + hostPID • cluster-admin SA&#10;mounts /host/var/run/cilium/tetragon/tetragon.log&#10;tails JSON → forwards to wazuh-worker :1514&#10;active-response: delete-pod.py (in-cluster k8s API)&#10;k8s-nodes group  •  control-plane toleration" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff8e1;strokeColor=#d79b00;fontSize=11;verticalAlign=top" vertex="1" parent="1">
          <mxGeometry x="590" y="800" width="560" height="170" as="geometry"/>
        </mxCell>

        <!-- ========== NAMESPACE: VULNERABLE-APPS ========== -->
        <mxCell id="ns_vuln" value="namespace: vulnerable-apps  (Tetragon allowlist)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;strokeWidth=2;fontSize=13;verticalAlign=top;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="1200" y="430" width="500" height="780" as="geometry"/>
        </mxCell>

        <mxCell id="dvwa" value="&lt;b&gt;DVWA&lt;/b&gt;&#10;PHP + MySQL  •  OWASP Top 10 (2007)&#10;Deployment + Service&#10;NodePort 30000 → :80" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6e6;strokeColor=#b85450;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="1220" y="470" width="460" height="110" as="geometry"/>
        </mxCell>

        <mxCell id="nodegoat" value="&lt;b&gt;OWASP NodeGoat&lt;/b&gt;&#10;Node.js lts-alpine  •  OWASP Top 10 (2017)&#10;custom image: nodegoat-local:latest&#10;NodePort 30001 → :4000  •  seeds via grunt db:seed" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6e6;strokeColor=#b85450;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="1220" y="600" width="460" height="110" as="geometry"/>
        </mxCell>

        <mxCell id="mongo" value="&lt;b&gt;nodegoat-mongo&lt;/b&gt;&#10;mongo:6 sidecar  •  emptyDir&#10;ClusterIP :27017" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6e6;strokeColor=#b85450;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="1220" y="730" width="460" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="scopenote" value="Tetragon scope:&#10;eBPF observes every exec/exit in this namespace.&#10;Anything else (kube-system, wazuh) is excluded by allowlist." style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontStyle=2" vertex="1" parent="1">
          <mxGeometry x="1220" y="830" width="460" height="80" as="geometry"/>
        </mxCell>

        <!-- =================== ARROWS =================== -->

        <!-- laptop → IAP -->
        <mxCell id="e1" style="endArrow=classic;html=1;edgeStyle=orthogonalEdgeStyle;strokeColor=#6c8ebf;strokeWidth=2" edge="1" parent="1" source="laptop" target="iap">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- IAP → VM label (and from there into VM) -->
        <mxCell id="e2" value="ssh / https / nodeports" style="endArrow=classic;html=1;edgeStyle=orthogonalEdgeStyle;strokeColor=#d6b656;strokeWidth=2;fontSize=10" edge="1" parent="1" source="iap" target="vmlabel">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- VM label → systemd -->
        <mxCell id="e3" style="endArrow=classic;html=1;edgeStyle=orthogonalEdgeStyle;strokeColor=#b85450;strokeWidth=2;dashed=1" edge="1" parent="1" source="vmlabel" target="systemd">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- systemd → dashboard (port-forward target) -->
        <mxCell id="e4" value="port-forward" style="endArrow=classic;html=1;edgeStyle=orthogonalEdgeStyle;strokeColor=#d79b00;strokeWidth=2;fontSize=10" edge="1" parent="1" source="systemd" target="dashboard">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- tetragon → hostlog (writes JSON) -->
        <mxCell id="e5" value="writes JSON" style="endArrow=classic;html=1;edgeStyle=orthogonalEdgeStyle;strokeColor=#82b366;strokeWidth=2;fontSize=10" edge="1" parent="1" source="tetragon" target="hostlog">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- hostlog → agentds (reads hostPath) -->
        <mxCell id="e6" value="tails (hostPath)" style="endArrow=classic;html=1;edgeStyle=orthogonalEdgeStyle;strokeColor=#82b366;strokeWidth=2;fontSize=10" edge="1" parent="1" source="hostlog" target="agentds">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- agentds → wm_worker (tcp 1514) -->
        <mxCell id="e7" value="tcp :1514" style="endArrow=classic;html=1;edgeStyle=orthogonalEdgeStyle;strokeColor=#d79b00;strokeWidth=2;fontSize=10" edge="1" parent="1" source="agentds" target="wm_worker">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- master ↔ worker cluster sync -->
        <mxCell id="e8" value="cluster sync :1516" style="endArrow=classic;startArrow=classic;html=1;edgeStyle=orthogonalEdgeStyle;strokeColor=#d79b00;strokeWidth=1;fontSize=10" edge="1" parent="1" source="wm_master" target="wm_worker">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- worker → indexer filebeat -->
        <mxCell id="e9" value="filebeat → wazuh-alerts-*" style="endArrow=classic;html=1;edgeStyle=orthogonalEdgeStyle;strokeColor=#d79b00;strokeWidth=2;fontSize=10" edge="1" parent="1" source="wm_worker" target="indexer">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- indexer → dashboard -->
        <mxCell id="e10" style="endArrow=classic;html=1;edgeStyle=orthogonalEdgeStyle;strokeColor=#d79b00;strokeWidth=2" edge="1" parent="1" source="indexer" target="dashboard">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- rulesync → master -->
        <mxCell id="e11" value="kubectl cp 0700-tetragon_rules.xml" style="endArrow=classic;html=1;edgeStyle=orthogonalEdgeStyle;strokeColor=#9673a6;strokeWidth=2;dashed=1;fontSize=10" edge="1" parent="1" source="rulesync" target="wm_master">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- rulesync → worker also -->
        <mxCell id="e11b" style="endArrow=classic;html=1;edgeStyle=orthogonalEdgeStyle;strokeColor=#9673a6;strokeWidth=2;dashed=1" edge="1" parent="1" source="rulesync" target="wm_worker">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ruleset → rulesync (source) -->
        <mxCell id="e12" style="endArrow=classic;html=1;edgeStyle=orthogonalEdgeStyle;strokeColor=#9673a6;strokeWidth=1;dashed=1" edge="1" parent="1" source="ruleset" target="rulesync">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- DVWA / NodeGoat observed by Tetragon (dashed) -->
        <mxCell id="e13" value="eBPF observes exec/exit" style="endArrow=classic;html=1;edgeStyle=orthogonalEdgeStyle;strokeColor=#82b366;strokeWidth=1;dashed=1;fontSize=10" edge="1" parent="1" source="dvwa" target="tetragon">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e14" style="endArrow=classic;html=1;edgeStyle=orthogonalEdgeStyle;strokeColor=#82b366;strokeWidth=1;dashed=1" edge="1" parent="1" source="nodegoat" target="tetragon">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- NodeGoat → mongo -->
        <mxCell id="e15" value="mongodb://:27017" style="endArrow=classic;html=1;edgeStyle=orthogonalEdgeStyle;strokeColor=#b85450;strokeWidth=2;fontSize=10" edge="1" parent="1" source="nodegoat" target="mongo">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- =================== LEGEND =================== -->
        <mxCell id="legendBox" value="&lt;b&gt;Legend&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666666;fontSize=11;verticalAlign=top;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="80" y="1260" width="1660" height="290" as="geometry"/>
        </mxCell>

        <mxCell id="lg_blue" value="laptop / client" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="100" y="1300" width="200" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="lg_amber" value="ingress / IAP / port-fwd" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="320" y="1300" width="200" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="lg_red" value="VM host / vulnerable apps" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="540" y="1300" width="200" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="lg_orange" value="Wazuh stack" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="760" y="1300" width="200" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="lg_green" value="Tetragon / observability" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="980" y="1300" width="200" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="lg_purple" value="rules + sync Job" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="1200" y="1300" width="200" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="lg_notes" value="&lt;b&gt;Flow summary&lt;/b&gt;&#10;1. eBPF kprobes in Tetragon DS observe execs in vulnerable-apps → write JSON to /var/run/cilium/tetragon/tetragon.log on each node.&#10;2. wazuh-agent DS on every node tails that hostPath log and forwards to wazuh-manager-worker on tcp 1514.&#10;3. Worker (analysisd) decodes Tetragon JSON, runs rules 700004–700099, writes alerts.json → filebeat → wazuh-indexer.&#10;4. Operator opens https://localhost:8443 via IAP tunnel → systemd port-forward → svc/dashboard → indexer.&#10;5. (Optional) rule 700099 logs every exec inside vulnerable-apps for forensic audit; active-response delete-pod.py can kill offending pods." style="text;html=1;align=left;verticalAlign=top;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="100" y="1360" width="1620" height="180" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
