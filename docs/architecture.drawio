<mxfile host="app.diagrams.net" type="device">
  <diagram name="Watergon" id="watergon-arch">
    <mxGraphModel dx="1800" dy="1200" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1600" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- =================== TITLE =================== -->
        <mxCell id="title" value="Watergon — Tetragon + Wazuh on kind on GCE" style="text;html=1;align=center;verticalAlign=middle;fontSize=22;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1720" height="30" as="geometry"/>
        </mxCell>

        <!-- =================== LAPTOP =================== -->
        <mxCell id="laptop" value="&lt;b&gt;Operator laptop&lt;/b&gt;&#10;Ghostty • zsh • gcloud + numpy" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12" vertex="1" parent="1">
          <mxGeometry x="60" y="80" width="260" height="60" as="geometry"/>
        </mxCell>

        <!-- =================== IAP =================== -->
