<mxfile host="app.diagrams.net" type="device">
  <diagram name="Watergon" id="watergon-arch">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="title" value="Watergon — data flow" style="text;html=1;align=center;fontSize=20;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1320" height="30" as="geometry"/>
        </mxCell>

        <!-- Laptop -->
        <mxCell id="laptop" value="Operator laptop" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="60" y="100" width="200" height="60" as="geometry"/>
        </mxCell>

        <!-- IAP -->
        <mxCell id="iap" value="GCP IAP" style="ellipse;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="60" y="220" width="200" height="60" as="geometry"/>
        </mxCell>

        <!-- VM box -->
        <mxCell id="vm" value="VM (kind cluster)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#b85450;strokeWidth=2;fontSize=14;fontStyle=1;verticalAlign=top" vertex="1" parent="1">
          <mxGeometry x="340" y="80" width="1020" height="780" as="geometry"/>
        </mxCell>

        <!-- Vulnerable apps -->
        <mxCell id="vuln" value="DVWA / NodeGoat" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="400" y="160" width="260" height="80" as="geometry"/>
        </mxCell>

        <!-- Tetragon DS -->
        <mxCell id="tetragon" value="Tetragon DS&#10;(eBPF)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="400" y="310" width="260" height="80" as="geometry"/>
        </mxCell>

        <!-- tetragon.log -->
        <mxCell id="log" value="tetragon.log&#10;(hostPath)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;dashed=1;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="400" y="460" width="260" height="80" as="geometry"/>
        </mxCell>

        <!-- Agent -->
        <mxCell id="agent" value="wazuh-agent DS" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="400" y="610" width="260" height="80" as="geometry"/>
        </mxCell>

        <!-- Manager -->
        <mxCell id="manager" value="wazuh-manager" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="780" y="610" width="260" height="80" as="geometry"/>
        </mxCell>

        <!-- Indexer -->
        <mxCell id="indexer" value="wazuh-indexer" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="780" y="460" width="260" height="80" as="geometry"/>
        </mxCell>

        <!-- Dashboard -->
        <mxCell id="dashboard" value="wazuh-dashboard" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="780" y="310" width="260" height="80" as="geometry"/>
        </mxCell>

        <!-- Arrows -->
        <mxCell id="a1" style="endArrow=classic;html=1;strokeWidth=2;edgeStyle=orthogonalEdgeStyle" edge="1" parent="1" source="laptop" target="iap"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="a2" style="endArrow=classic;html=1;strokeWidth=2;edgeStyle=orthogonalEdgeStyle" edge="1" parent="1" source="iap" target="dashboard"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="a3" value="observe" style="endArrow=classic;html=1;strokeWidth=2;edgeStyle=orthogonalEdgeStyle;dashed=1;fontSize=12" edge="1" parent="1" source="vuln" target="tetragon"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="a4" value="write" style="endArrow=classic;html=1;strokeWidth=2;edgeStyle=orthogonalEdgeStyle;fontSize=12" edge="1" parent="1" source="tetragon" target="log"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="a5" value="tail" style="endArrow=classic;html=1;strokeWidth=2;edgeStyle=orthogonalEdgeStyle;fontSize=12" edge="1" parent="1" source="log" target="agent"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="a6" value="1514" style="endArrow=classic;html=1;strokeWidth=2;edgeStyle=orthogonalEdgeStyle;fontSize=12" edge="1" parent="1" source="agent" target="manager"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="a7" value="filebeat" style="endArrow=classic;html=1;strokeWidth=2;edgeStyle=orthogonalEdgeStyle;fontSize=12" edge="1" parent="1" source="manager" target="indexer"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="a8" style="endArrow=classic;html=1;strokeWidth=2;edgeStyle=orthogonalEdgeStyle" edge="1" parent="1" source="indexer" target="dashboard"><mxGeometry relative="1" as="geometry"/></mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
