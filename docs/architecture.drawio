          <mxGeometry x="380" y="78" width="360" height="64" as="geometry"/>
        </mxCell>

        <!-- VM external label (right of IAP) -->
        <mxCell id="vmlabel" value="&lt;b&gt;VM tetragon-wazuh-lab&lt;/b&gt;&#10;e2-standard-8 SPOT • 200 GB pd-balanced • no public IP" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12" vertex="1" parent="1">
          <mxGeometry x="800" y="78" width="420" height="64" as="geometry"/>
        </mxCell>

        <!-- =================== GCP PROJECT =================== -->
